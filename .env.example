# API bearer token (optional; if set, all /api/* and /hubs/trading require auth)
WEB_API_TOKEN=

# Serilog file logs (daily rolling: logs/polytrader-YYYYMMDD.log)
POLYTRADER_LOG_DIR=logs
# Main log: polytrader-YYYYMMDD.log | Trades only: trade-execution-YYYYMMDD.log (same folder)
# POLYTRADER_LOG_LEVEL=Debug

# Polymarket trading (required for Live mode)
POLYMARKET_PRIVATE_KEY=0x...
# Funder/deposit address — required for signature types 1–3 (proxy, Safe, POLY_1271)
POLYMARKET_FUNDER_ADDRESS=
# 0=EOA, 1=proxy, 2=Gnosis Safe (proxy), 3=POLY_1271
POLYMARKET_SIGNATURE_TYPE=0
# Optional Polygon RPC — full URL only (not an API key alone). Empty = https://polygon-rpc.com
# POLYMARKET_POLYGON_RPC=https://polygon-mainnet.g.alchemy.com/v2/YOUR_KEY
POLYMARKET_POLYGON_RPC=

# Production CORS (comma-separated origins; only needed if UI is on another domain)
# Example: https://trader.example.com
CORS_ORIGINS=

# Telegram operator bot (optional; runs inside the API process)
# Create a bot via @BotFather, then set your numeric user ID from @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_IDS=

# Frontend build (Docker production: leave both empty — nginx proxies /api and /hubs)
VITE_API_URL=
# Do NOT bake API token into production builds; enter it in the browser UI
VITE_API_TOKEN=

# Docker web port mapping (prod VPS: bind localhost only for host nginx)
# WEB_PUBLISH=127.0.0.1:8081:80

# Live entry order mode (Limit / Market) is configured in the app Settings UI.
# Legacy one-time import when upgrading DB: POLYTRADER_LIVE_ENTRY_ORDER_MODE=Market
# Limit wave 1: full stake; wave 2: remainder only (no third wave, no taker top-up)
POLYTRADER_LIVE_MAKER_FILL_WAIT_SECONDS=45
POLYTRADER_LIVE_MAKER_REMAINDER_FILL_WAIT_SECONDS=20
# Patience entry after quote > max band: wait up to N seconds (1–180, default 60)
POLYTRADER_ENTRY_MAX_WAIT_SECONDS=60
# Optional override for patience max bid (default 0.52 = same as immediate entry)
# POLYTRADER_PATIENCE_MAX_ENTRY_PRICE=0.52
# Post-only: ticks below ask (1=default, 2=more conservative vs cross)
# POLYTRADER_POST_ONLY_ASK_TICK_MARGIN=1
# Retries stepping limit down on post-only cross (default 5)
# POLYTRADER_POST_ONLY_CROSS_TICK_RETRIES=5
# Wait after 5m open before first live entry (ms, 0=off, default 300)
# POLYTRADER_ENTRY_OPEN_DELAY_MS=300
# Use WS best_bid_ask when younger than N ms (REST still used before PlaceOrder)
# POLYTRADER_WS_QUOTE_MAX_AGE_MS=500
# REST poll interval while waiting for maker fill (default 250; user WS can wake earlier)
# POLYTRADER_MAKER_FILL_POLL_MS=250

# Local-only: remote deploy script (deploy/remote-deploy.ps1); not used by API/Docker on VPS
# POLYTRADER_DEPLOY_HOST=203.0.113.10
# POLYTRADER_DEPLOY_USER=root
# POLYTRADER_DEPLOY_DIR=/opt/poly-trader