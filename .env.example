# API bearer token (optional; if set, all /api/* and /hubs/trading require auth)
WEB_API_TOKEN=

# Serilog file logs (daily rolling: logs/polytrader-YYYYMMDD.log)
POLYTRADER_LOG_DIR=logs
# POLYTRADER_LOG_LEVEL=Debug

# Polymarket trading (required for Live mode)
POLYMARKET_PRIVATE_KEY=0x...
# Funder/deposit address — required for signature types 1–3 (proxy, Safe, POLY_1271)
POLYMARKET_FUNDER_ADDRESS=
# 0=EOA, 1=proxy, 2=Gnosis Safe (proxy), 3=POLY_1271
POLYMARKET_SIGNATURE_TYPE=0
# Optional Polygon RPC — full URL only (not an API key alone). Empty = https://polygon-rpc.com
# POLYMARKET_POLYGON_RPC=https://polygon-mainnet.g.alchemy.com/v2/YOUR_KEY
POLYMARKET_POLYGON_RPC=

# Production CORS (comma-separated origins)
CORS_ORIGINS=

# Telegram operator bot (optional; runs inside the API process)
# Create a bot via @BotFather, then set your numeric user ID from @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_IDS=

# Frontend (empty VITE_API_URL = same-origin /api proxy in Docker nginx)
VITE_API_URL=http://localhost:5088
VITE_API_TOKEN=
