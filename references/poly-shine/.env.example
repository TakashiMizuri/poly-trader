# Local SQLite file (created automatically). Use the same path for bot + worker.
SQLITE_PATH=./data/polyshine.sqlite

# Telegram — same bot for control + alerts
TELEGRAM_BOT_TOKEN=
# Comma-separated numeric user IDs allowed to control the bot (DM the bot from that account to learn your id via @userinfobot)
TELEGRAM_ADMIN_CHAT_IDS=

# Worker / follower trading (Polymarket CLOB)
POLYMARKET_PRIVATE_KEY=
POLYMARKET_FUNDER_ADDRESS=
# 0=EOA, 1=POLY_PROXY, 2=GNOSIS_SAFE, 3=POLY_1271 (Polymarket.com deposit / email wallet — use if balance is $0 with 1)
POLYMARKET_SIGNATURE_TYPE=3


# Web operator UI (apps/api + apps/web)
WEB_API_PORT=3001
# API auth — browser Bearer token must match this exactly
WEB_API_TOKEN=change-me-to-a-long-random-secret
WEB_ORIGIN=http://localhost:5173
# Optional dev convenience: must be identical to WEB_API_TOKEN (Vite reads from repo root .env)
VITE_API_TOKEN=change-me-to-a-long-random-secret
